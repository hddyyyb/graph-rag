# Application
APP_NAME=graph-rag
LOG_LEVEL=INFO

# Retrieval
VECTOR_TOP_K=5
GRAPH_TOP_K=5
FUSION_ALPHA=0.5
FUSION_BETA=0.5
ENABLE_FUSION_SCORE_NORMALIZATION=true

# Chunking
CHUNKING_STRATEGY=recursive
CHUNK_SIZE=400
CHUNK_OVERLAP=50

# Backend selectors
EMBEDDING_BACKEND=sentence_transformer
VECTOR_STORE_BACKEND=qdrant
GRAPH_STORE_BACKEND=neo4j
LLM_BACKEND=fake

# Embedding
EMBEDDING_MODEL_NAME_OR_PATH=E:/Reasarch/hf_models/all-MiniLM-L6-v2
NORMALIZE_EMBEDDINGS=false

# SQLite
SQLITE_PATH=:memory:

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=graphrag_dev

# Graph retrieval
GRAPH_EXPAND_HOPS=1
GRAPH_EXPAND_PER_TERM_LIMIT=2
GRAPH_MAX_EXPANDED_TERMS=10
GRAPH_DIRECT_HIT_WEIGHT=1.0
GRAPH_EXPANDED_HIT_WEIGHT=0.5
GRAPH_EXPANSION_SCORE_CAP=2.0

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_password_here
NEO4J_DATABASE=neo4j

# Local LLM
LOCAL_LLM_BASE_URL=http://localhost:11434
LOCAL_LLM_MODEL=llama3

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5
OPENAI_INSTRUCTIONS=You are a helpful assistant.